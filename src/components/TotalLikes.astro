---
interface Props {
  label?: string;
}

const { label = "Total des likes" } = Astro.props;
---

<div class="total-likes-container">
  <div class="total-likes">
    <svg class="icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <span class="label">{label} :</span>
    <span class="count">0</span>
  </div>
</div>

<style>
  .total-likes-container {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 1rem;
  }

  .total-likes {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--surface-2, #f5f5f5);
    border: 1px solid var(--surface-3, #e0e0e0);
    border-radius: 1rem;
    font-size: 0.95rem;
    color: var(--text-1, #333);
  }

  .icon {
    color: var(--brand, #ff6b6b);
  }

  .label {
    font-weight: 500;
  }

  .count {
    font-weight: 700;
    color: var(--brand, #ff6b6b);
    min-width: 2rem;
    text-align: center;
  }

  @media (prefers-color-scheme: dark) {
    .total-likes {
      background: var(--surface-2, #2a2a2a);
      border-color: var(--surface-3, #3a3a3a);
      color: var(--text-1, #e0e0e0);
    }
  }
</style>

<script>
  interface LikeData {
    [postSlug: string]: number;
  }

  const STORAGE_KEY = 'blog-post-likes';

  function getTotalLikes(): number {
    try {
      const data = localStorage.getItem(STORAGE_KEY);
      if (!data) return 0;
      
      const likes: LikeData = JSON.parse(data);
      return Object.values(likes).reduce((sum, count) => sum + count, 0);
    } catch (error) {
      console.error('Error reading total likes from localStorage:', error);
      return 0;
    }
  }

  function updateTotalLikesDisplay(): void {
    const countElements = document.querySelectorAll<HTMLElement>('.total-likes .count');
    const total = getTotalLikes();
    
    countElements.forEach(element => {
      element.textContent = total.toString();
    });
  }

  function initializeTotalLikes(): void {
    updateTotalLikesDisplay();

    window.addEventListener('storage', (e) => {
      if (e.key === STORAGE_KEY) {
        updateTotalLikesDisplay();
      }
    });

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.like-button')) {
        setTimeout(updateTotalLikesDisplay, 100);
      }
    });
  }

  document.addEventListener('astro:page-load', initializeTotalLikes);
</script>
