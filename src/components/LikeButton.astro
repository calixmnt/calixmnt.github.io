---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="like-button-container">
  <button 
    class="like-button" 
    data-post-slug={postSlug}
    aria-label="J'aime cet article"
  >
    <svg class="heart-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <span class="like-count">0</span>
  </button>
</div>

<style>
  .like-button-container {
    display: flex;
    justify-content: center;
    margin: 2rem 0;
  }

  .like-button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--surface-2, #f5f5f5);
    border: 2px solid var(--surface-3, #e0e0e0);
    border-radius: 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-1, #333);
  }

  .like-button:hover {
    transform: scale(1.05);
    background: var(--surface-3, #e0e0e0);
  }

  .like-button.liked {
    background: var(--brand, #ff6b6b);
    border-color: var(--brand, #ff6b6b);
    color: white;
  }

  .like-button.liked .heart-icon {
    fill: currentColor;
    animation: heartbeat 0.3s ease;
  }

  .heart-icon {
    transition: fill 0.3s ease;
  }

  .like-count {
    min-width: 1.5rem;
    text-align: center;
  }

  @keyframes heartbeat {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.3);
    }
  }

  @media (prefers-color-scheme: dark) {
    .like-button {
      background: var(--surface-2, #2a2a2a);
      border-color: var(--surface-3, #3a3a3a);
      color: var(--text-1, #e0e0e0);
    }

    .like-button:hover {
      background: var(--surface-3, #3a3a3a);
    }
  }
</style>

<script>
  interface LikeData {
    [postSlug: string]: number;
  }

  const STORAGE_KEY = 'blog-post-likes';
  const LIKED_POSTS_KEY = 'blog-liked-posts';

  function getLikes(): LikeData {
    try {
      const data = localStorage.getItem(STORAGE_KEY);
      return data ? JSON.parse(data) : {};
    } catch (error) {
      console.error('Error reading likes from localStorage:', error);
      return {};
    }
  }

  function saveLikes(likes: LikeData): void {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(likes));
    } catch (error) {
      console.error('Error saving likes to localStorage:', error);
    }
  }

  function getLikedPosts(): Set<string> {
    try {
      const data = localStorage.getItem(LIKED_POSTS_KEY);
      return data ? new Set(JSON.parse(data)) : new Set();
    } catch (error) {
      console.error('Error reading liked posts from localStorage:', error);
      return new Set();
    }
  }

  function saveLikedPosts(likedPosts: Set<string>): void {
    try {
      localStorage.setItem(LIKED_POSTS_KEY, JSON.stringify([...likedPosts]));
    } catch (error) {
      console.error('Error saving liked posts to localStorage:', error);
    }
  }

  function initializeLikeButton(button: HTMLButtonElement): void {
    const postSlug = button.dataset.postSlug;
    if (!postSlug) return;

    const countSpan = button.querySelector('.like-count');
    if (!countSpan) return;

    const likes = getLikes();
    const likedPosts = getLikedPosts();

    const currentLikes = likes[postSlug] || 0;
    countSpan.textContent = currentLikes.toString();

    if (likedPosts.has(postSlug)) {
      button.classList.add('liked');
    }

    button.addEventListener('click', () => {
      const likes = getLikes();
      const likedPosts = getLikedPosts();
      const isLiked = likedPosts.has(postSlug);

      if (isLiked) {
        likes[postSlug] = Math.max(0, (likes[postSlug] || 0) - 1);
        likedPosts.delete(postSlug);
        button.classList.remove('liked');
      } else {
        likes[postSlug] = (likes[postSlug] || 0) + 1;
        likedPosts.add(postSlug);
        button.classList.add('liked');
      }

      saveLikes(likes);
      saveLikedPosts(likedPosts);
      countSpan.textContent = likes[postSlug].toString();
    });
  }

  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.like-button');
    buttons.forEach(initializeLikeButton);
  });
</script>
